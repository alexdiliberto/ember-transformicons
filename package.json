{
  "name": "ember-transformicons",
  "version": "7.0.0",
  "description": "Transformicons for Ember: Animated icons, symbols and buttons",
  "keywords": [
    "ember-addon",
    "ember",
    "ember-cli",
    "transformicon",
    "navicon",
    "icon",
    "transform",
    "animation"
  ],
  "repository": "https://github.com/alexdiliberto/ember-transformicons",
  "license": "MIT",
  "author": "Alex DiLiberto <npm@alexdiliberto.com>",
  "directories": {
    "doc": "doc",
    "test": "tests"
  },
  "homepage": "https://alexdiliberto.github.io/ember-transformicons",
  "bugs": {
    "url": "https://github.com/alexdiliberto/ember-transformicons/issues"
  },
  "scripts": {
    "analyze": "broccoli-concat-analyser ./concat-stats-for",
    "build": "ember build",
    "build:prod": "ember build -prod",
    "build:prod:stats": "CONCAT_STATS=true yarn build:prod",
    "clean": "rm -rf dist tmp node_modules concat-stats-for",
    "changelog": "lerna-changelog",
    "format": "prettier . --cache --write",
    "lint": "concurrently \"yarn:lint:*(!fix)\" --names \"lint:\" --prefixColors auto",
    "lint:css": "echo \"skip css lint\"",
    "lint:fix": "concurrently \"yarn:lint:*:fix\" --names \"fix:\" --prefixColors auto && yarn format",
    "lint:format": "prettier . --cache --check",
    "lint:hbs": "ember-template-lint .",
    "lint:hbs:fix": "ember-template-lint . --fix",
    "lint:js": "eslint . --ext .js,.ts --cache",
    "lint:js:fix": "eslint . --ext .js,.ts --fix",
    "lint:dependency": "ember dependency-lint",
    "lint:types": "tsc --skipLibCheck",
    "release": "release-it",
    "start": "ember serve",
    "start:inspect": "node --inspect-brk yarn start",
    "test": "concurrently \"yarn:lint\" \"yarn:test:*\" --names \"lint,test:\" --prefixColors auto",
    "test:ember": "ember test",
    "test:ember-compatibility": "ember try:each"
  },
  "dependencies": {
    "@babel/core": "^7.28.4",
    "@ember/string": "^3.0.0",
    "@glimmer/component": "1.1.2",
    "ember-auto-import": "^2.11.1",
    "ember-cli-babel": "8.2.0",
    "ember-cli-htmlbars": "^6.3.0",
    "ember-decorators": "^6.1.1",
    "ember-template-imports": "^4.3.0",
    "ember-truth-helpers": "^3.0.0"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.28.4",
    "@babel/plugin-proposal-decorators": "^7.28.0",
    "@ember/edition-utils": "^1.2.0",
    "@ember/optional-features": "^2.2.0",
    "@ember/test-helpers": "^5.3.0",
    "@ember/test-waiters": "^4.1.1",
    "@embroider/macros": "^1.19.1",
    "@embroider/test-setup": "^4.0.0",
    "@eslint/js": "^9.37.0",
    "@types/ember": "^3.16.5",
    "@types/ember-qunit": "^3.4.15",
    "@types/ember-resolver": "^5.0.10",
    "@types/ember__application": "^3.16.3",
    "@types/ember__array": "^3.16.4",
    "@types/ember__component": "^3.16.6",
    "@types/ember__controller": "^3.16.6",
    "@types/ember__debug": "^3.16.5",
    "@types/ember__engine": "^3.16.3",
    "@types/ember__error": "^3.16.1",
    "@types/ember__object": "^3.12.6",
    "@types/ember__polyfills": "^3.12.1",
    "@types/ember__routing": "^3.16.15",
    "@types/ember__runloop": "^3.16.3",
    "@types/ember__service": "^3.16.1",
    "@types/ember__string": "^3.16.3",
    "@types/ember__template": "^3.16.1",
    "@types/ember__test": "^3.16.1",
    "@types/ember__utils": "^3.16.2",
    "@types/htmlbars-inline-precompile": "^1.0.1",
    "@types/qunit": "^2.19.13",
    "@types/rsvp": "^4.0.6",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "broccoli-asset-rev": "^3.0.0",
    "broccoli-concat-analyser": "^5.0.0",
    "concurrently": "^9.2.1",
    "ember-cli": "~6.8.0",
    "ember-cli-addon-docs": "^8.0.8",
    "ember-cli-addon-docs-yuidoc": "^1.1.0",
    "ember-cli-clean-css": "^3.0.0",
    "ember-cli-dependency-checker": "^3.3.3",
    "ember-cli-dependency-lint": "^2.0.1",
    "ember-cli-deploy": "^2.0.0",
    "ember-cli-deploy-build": "^3.0.0",
    "ember-cli-deploy-git": "^1.3.4",
    "ember-cli-deploy-git-ci": "^1.0.1",
    "ember-cli-deprecation-workflow": "^3.4.0",
    "ember-cli-favicon": "^3.0.0",
    "ember-cli-inject-live-reload": "^2.1.0",
    "ember-cli-sri": "^2.1.1",
    "ember-cli-terser": "^4.0.2",
    "ember-data": "^5.7.0",
    "ember-load-initializers": "^3.0.1",
    "ember-open-browser": "^1.0.0",
    "ember-percy": "1.6.0",
    "ember-qunit": "^9.0.4",
    "ember-resolver": "^13.1.1",
    "ember-source": "~6.8.0",
    "ember-source-channel-url": "^3.0.0",
    "ember-template-lint": "^6.1.0",
    "ember-try": "^4.0.0",
    "eslint": "^9.37.0",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-ember": "^12.7.4",
    "eslint-plugin-n": "^17.23.1",
    "eslint-plugin-qunit": "^8.2.5",
    "eslint-plugin-unicorn": "^49.0.0",
    "globals": "^15.15.0",
    "lerna-changelog": "^2.2.0",
    "loader.js": "4.7.0",
    "prettier": "^3.6.2",
    "prettier-plugin-ember-template-tag": "^2.1.0",
    "qunit": "^2.24.2",
    "qunit-dom": "^3.5.0",
    "release-it": "^14.12.1",
    "release-it-lerna-changelog": "^4.0.1",
    "stylelint": "^16.25.0",
    "stylelint-config-standard": "^36.0.1",
    "typescript": "^5.6.3",
    "webpack": "^5.102.1"
  },
  "peerDependencies": {
    "ember-source": ">= 4.0.0"
  },
  "engines": {
    "node": ">= 20.11"
  },
  "ember": {
    "edition": "octane"
  },
  "ember-addon": {
    "configPath": "tests/dummy/config",
    "demoURL": "https://alexdiliberto.com/ember-transformicons",
    "versionCompatibility": {
      "ember": ">=3.16"
    }
  },
  "release-it": {
    "plugins": {
      "release-it-lerna-changelog": {
        "infile": "CHANGELOG.md",
        "launchEditor": true
      }
    },
    "git": {
      "tagName": "v${version}"
    },
    "github": {
      "release": true
    },
    "npm": {
      "publish": true
    }
  },
  "changelog": {
    "ignoreCommitters": [
      "dependabot"
    ]
  },
  "resolutions": {
    "@glimmer/component": "1.1.2",
    "@babel/traverse": "^7.28.4"
  },
  "volta": {
    "node": "20.19.5",
    "yarn": "1.22.22"
  }
}
